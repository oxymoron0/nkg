# Notion workspace slug used by the right-click context menu to open pages
# in the correct workspace (https://www.notion.so/<slug>/<pageId>).
#
# **Required.** `vite.config.ts` fails the build and dev server startup when
# this variable is unset or empty — there is no silent fallback. Copy this
# file to `.env` and edit the value, or pass `--build-arg` to `docker build`.
#
# Example Docker build for a different workspace:
#   docker build --build-arg VITE_NKG_NOTION_WORKSPACE=acme ...
VITE_NKG_NOTION_WORKSPACE=leorca
